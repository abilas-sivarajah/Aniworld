# Optional defaults, seeded into a per-browser config cookie on first visit.
# All of these can also be changed at runtime in the app's settings dialog.

# Default host URL to scrape (must end with a slash).
DEFAULT_HOST_URL=https://s.to/

# Default site type: "serie" (SerienStream) or "anime" (AniWorld / AniCloud).
DEFAULT_SITE=serie

# Bypass TLS certificate validation for unofficial / mirror hosts ("true"/"false").
IGNORE_CERT=false

# Optional SHA-256 (hex) password hash to gate access to the app.
# Leave empty to disable the login gate.
PASSWORD_HASH_SHA256=
